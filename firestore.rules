rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Target the 'expenses' collection specifically
    match /expenses/{expenseId} {
      
      // ALLOW CREATE: only if the requested userId matches the logged-in user
      allow create: if request.auth != null 
                    && request.resource.data.userId == request.auth.uid;
      
      // ALLOW READ/UPDATE/DELETE: only if the existing document belongs to the logged-in user
      allow read, update, delete: if request.auth != null 
                                  && resource.data.userId == request.auth.uid;
    }

    // Block absolutely everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
    
  }
}
